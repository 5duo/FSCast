<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background"
    tools:context=".ui.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="投屏控制"
            app:titleTextColor="@color/ios_text_primary" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="150dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 板块1: 悬浮窗显示控制 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/ios_card_background"
                app:strokeWidth="1dp"
                app:strokeColor="@color/ios_separator">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="悬浮窗"
                        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/statusIndicator"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="10dp"
                            app:cardCornerRadius="5dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/ios_text_tertiary" />

                        <TextView
                            android:id="@+id/castingStatusText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="等待投屏"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                            android:textColor="@color/ios_text_secondary"
                            android:textSize="17sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggleWindowButton"
                            style="@style/IosFilledButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:minWidth="80dp"
                            android:text="显示"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 板块2: 播放控制 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/ios_card_background"
                app:strokeWidth="1dp"
                app:strokeColor="@color/ios_separator">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="播放控制"
                        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <!-- 进度条 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/currentPositionText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00:00"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="@color/ios_text_secondary"
                                android:fontFamily="monospace"
                                android:textSize="13sp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/durationText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00:00"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="@color/ios_text_secondary"
                                android:fontFamily="monospace"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/progressSlider"
                            style="@style/ProgressSlider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:valueFrom="0"
                            android:valueTo="100"
                            android:stepSize="0.1" />

                    </LinearLayout>

                    <!-- 播放按钮 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <!-- 上一集 -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/previousButton"
                            style="@style/IconButton"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:contentDescription="上一集"
                            app:icon="@android:drawable/ic_media_previous"
                            app:iconSize="22dp"
                            app:iconTint="@color/ios_blue" />

                        <!-- 播放/暂停 -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/playPauseButton"
                            style="@style/IconButton"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="10dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:contentDescription="播放/暂停"
                            app:icon="@drawable/ic_play"
                            app:iconSize="26dp"
                            app:iconTint="@color/ios_blue" />

                        <!-- 停止 -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/stopButton"
                            style="@style/IconButton"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:contentDescription="停止"
                            app:icon="@android:drawable/ic_menu_close_clear_cancel"
                            app:iconSize="22dp"
                            app:iconTint="@color/ios_blue" />

                        <!-- 下一集 -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/nextButton"
                            style="@style/IconButton"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:contentDescription="下一集"
                            app:icon="@android:drawable/ic_media_next"
                            app:iconSize="22dp"
                            app:iconTint="@color/ios_blue" />

                        <!-- 静音按钮 -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/muteButton"
                            style="@style/IconButton"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_marginStart="10dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:contentDescription="静音"
                            app:icon="@android:drawable/ic_lock_silent_mode"
                            app:iconSize="22dp"
                            app:iconTint="@color/ios_blue" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 板块3: 悬浮窗设置 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/ios_card_background"
                app:strokeWidth="1dp"
                app:strokeColor="@color/ios_separator">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="设置"
                        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <!-- 比例选择 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="屏幕比例"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="17sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/ratio169Button"
                            style="@style/AspectRatioButton"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="16:9"
                            android:textSize="15sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/ratio43Button"
                            style="@style/AspectRatioButton"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="6dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="4:3"
                            android:textSize="15sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/ratioPortraitButton"
                            style="@style/AspectRatioButton"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:text="竖屏"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <!-- 位置控制 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="位置"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="17sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="X"
                            android:textSize="15sp"
                            android:textColor="@color/ios_text_secondary"
                            android:textStyle="bold" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/positionXSlider"
                            style="@style/CustomSlider"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:stepSize="10"
                            android:valueFrom="0"
                            android:valueTo="1920"
                            android:value="720" />

                        <TextView
                            android:id="@+id/positionXValue"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="720"
                            android:textSize="15sp"
                            android:textColor="@color/ios_text_secondary"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="Y"
                            android:textSize="15sp"
                            android:textColor="@color/ios_text_secondary"
                            android:textStyle="bold" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/positionYSlider"
                            style="@style/CustomSlider"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:stepSize="10"
                            android:valueFrom="0"
                            android:valueTo="720"
                            android:value="220" />

                        <TextView
                            android:id="@+id/positionYValue"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="220"
                            android:textSize="15sp"
                            android:textColor="@color/ios_text_secondary"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                    <!-- 大小控制 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="大小"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="17sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="W"
                            android:textSize="15sp"
                            android:textColor="@color/ios_text_secondary"
                            android:textStyle="bold" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sizeSlider"
                            style="@style/CustomSlider"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:stepSize="10"
                            android:valueFrom="160"
                            android:valueTo="1920"
                            android:value="480" />

                        <TextView
                            android:id="@+id/sizeValue"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="480"
                            android:textSize="15sp"
                            android:textColor="@color/ios_text_secondary"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                    <!-- 透明度控制 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="透明度"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="17sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="%"
                            android:textSize="15sp"
                            android:textColor="@color/ios_text_secondary"
                            android:textStyle="bold" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/alphaSlider"
                            style="@style/CustomSlider"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:stepSize="1"
                            android:valueFrom="0"
                            android:valueTo="100"
                            android:value="100" />

                        <TextView
                            android:id="@+id/alphaValue"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="100%"
                            android:textSize="15sp"
                            android:textColor="@color/ios_text_secondary"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                    <!-- 快捷操作 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/centerButton"
                            style="@style/IosFilledButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="居中"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/maximizeButton"
                            style="@style/IosFilledButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="最大化"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 板块4: 音频输出 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/ios_card_background"
                app:strokeWidth="1dp"
                app:strokeColor="@color/ios_separator">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="音频输出"
                        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/currentAudioOutput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="系统扬声器"
                            android:textSize="16sp"
                            android:textColor="@color/ios_text_secondary"
                            android:ellipsize="end"
                            android:maxLines="1" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/audioOutputButton"
                            style="@style/IosOutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginStart="12dp"
                            android:minWidth="80dp"
                            android:text="检查蓝牙"
                            android:textSize="16sp" />

                    </LinearLayout>

                    <!-- 蓝牙设备提示 -->
                    <TextView
                        android:id="@+id/bluetoothHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="点击检查蓝牙连接状态，已连接时投屏声音会自动输出到蓝牙设备"
                        android:textSize="13sp"
                        android:textColor="@color/ios_text_tertiary" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 底部信息 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="8dp"
                android:text="DLNA投屏接收器"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/ios_text_tertiary"
                android:textSize="13sp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
